<h1><%= @goal.title %></h1>
<p>Target: <%= @goal.current_value %> / <%= @goal.target_value %></p>
<p>From <%= @goal.start_date %> to <%= @goal.end_date %></p>

<%= link_to "Edit", edit_habit_goal_path(@habit, @goal) %>
<%= link_to "Delete", habit_goal_path(@habit, @goal), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>

<h2>Check-ins</h2>
<ul>
  <% @goal.check_ins.each do |check_in| %>
    <li><%= check_in.date %> — value: <%= check_in.value %> — <%= check_in.note %></li>
  <% end %>
</ul>

<h3>New Check-in</h3>
<%= form_with model: @check_in, url: habit_goal_check_ins_path(@habit, @goal), local: true do |form| %>
  <div class="field">
    <%= form.label :date %>
    <%= form.date_field :date %>
  </div>
  <div class="field">
    <%= form.label :value %>
    <%= form.number_field :value %>
  </div>
  <div class="field">
    <%= form.label :note %>
    <%= form.text_area :note %>
  </div>
  <%= form.submit "Add Check-in" %>
<% end %>